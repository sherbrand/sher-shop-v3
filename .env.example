# ============================================================
#  SHER Web Store — environment template
#  Copy this file to .env.local, then fill in the REAL values.
#    cp .env.example .env.local
#  .env.local is gitignored and MUST NEVER be committed.
#  (This repo is PUBLIC — a committed secret is a leaked secret.)
# ============================================================

# Your store's myshopify domain. Not secret — it's just config.
SHOPIFY_STORE_DOMAIN=sher-9551.myshopify.com

# Storefront API access token. Treat as a SECRET (server-side only).
#   Where: Shopify admin -> Headless channel "Sher Headless"
#          -> Storefront API -> Manage -> "Public access token" -> copy.
#   No NEXT_PUBLIC_ prefix on purpose: that keeps it OUT of the browser bundle.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=paste_your_storefront_token_here
